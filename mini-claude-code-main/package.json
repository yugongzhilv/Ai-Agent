  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yugongzhilv/Ai-Agent.git"
  },
  "bugs": {
    "url": "https://github.com/yugongzhilv/Ai-Agent/issues"
  },
  "homepage": "https://github.com/yugongzhilv/Ai-Agent#readme",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
